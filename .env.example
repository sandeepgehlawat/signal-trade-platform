# Signal Trade Platform - Environment Configuration
# Copy this to .env and fill in your values

# ============================================================================
# SERVER PORTS
# ============================================================================
PORT=3460                      # API server port
FEED_PORT=3462                 # Feed server port (SSE)

# ============================================================================
# PRODUCTION MODE
# ============================================================================
NODE_ENV=development           # Set to "production" for production deployment

# ============================================================================
# API AUTHENTICATION
# ============================================================================
# Optional: Require API token for sensitive endpoints
# API_TOKEN=your-secret-token
# SIGNAL_TRADE_API_TOKEN=your-secret-token

# ============================================================================
# INTERNAL SERVICE COMMUNICATION
# ============================================================================
# Secret for API server -> Feed server communication
# MUST be changed in production
FEED_INTERNAL_SECRET=dev_secret_change_in_prod
FEED_SERVER_URL=http://localhost:3462

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Comma-separated list of allowed origins (used in production mode)
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# ============================================================================
# PROXY CONFIGURATION
# ============================================================================
# Set to "true" if running behind a reverse proxy (nginx, cloudflare, etc.)
TRUST_PROXY=false
# Comma-separated list of trusted proxy IPs (only used when TRUST_PROXY=true)
# TRUSTED_PROXY_IPS=127.0.0.1,::1

# ============================================================================
# TRADING MODE
# ============================================================================
# Set to "false" for live trading (CAUTION: Real money!)
PAPER_MODE=true

# ============================================================================
# EXCHANGE CREDENTIALS (For execution)
# ============================================================================

# Hyperliquid (perpetual futures)
# HL_PRIVATE_KEY=0x...

# Polymarket (prediction markets)
# PM_PRIVATE_KEY=0x...
# PM_FUNDER_ADDRESS=0x...

# OKX DEX (spot swaps via OnchainOS)
# OKX_API_KEY=
# OKX_SECRET_KEY=
# OKX_API_PASSPHRASE=
# OKX_PROJECT_ID=

# ============================================================================
# OPTIONAL: TWITTER API (Better tweet extraction)
# ============================================================================
# X_BEARER_TOKEN=

# ============================================================================
# USDC PAYMENT CONFIGURATION
# ============================================================================
# Deposit wallets for receiving USDC payments (your company wallets)
# Users send USDC to these addresses to upgrade to Pro tier

# Polygon (USDC on Polygon PoS)
DEPOSIT_WALLET_POLYGON=
POLYGON_RPC_URL=https://polygon-rpc.com

# X Layer (OKX L2)
DEPOSIT_WALLET_XLAYER=
XLAYER_RPC_URL=https://rpc.xlayer.tech

# Solana
DEPOSIT_WALLET_SOLANA=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ============================================================================
# DATABASE
# ============================================================================
# SQLite database file (default: ./signal-trade.db)
# DB_PATH=./signal-trade.db
